# Public client env example
# Copy values into `.env.local` or your build environment.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_INVITE_BASE_URL=
EXPO_PUBLIC_ADMIN_WEB_URL=
EXPO_PUBLIC_APP_STORE_URL=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=production
EXPO_PUBLIC_SENTRY_RELEASE=
# Sentry token roles:
# - SENTRY_AUTH_TOKEN: release/source-map upload only.
# - SENTRY_READ_AUTH_TOKEN: read-only Sentry API queries for projects/issues/events.
# Agents must use SENTRY_READ_AUTH_TOKEN for Sentry investigation; do not fall back to SENTRY_AUTH_TOKEN.
SENTRY_AUTH_TOKEN=
SENTRY_READ_AUTH_TOKEN=
SENTRY_ORG=hanhwa-lifelab
SENTRY_PROJECT=react-native

# Server/Edge-only values. Never expose them with an EXPO_PUBLIC_ prefix.
FC_APP_SESSION_TOKEN_SECRET=
# Verify-only key for a staged app-session rotation. Never reuse a bridge-token secret here.
FC_APP_SESSION_TOKEN_PREVIOUS_SECRET=
BOARD_AUTOMATION_TOKEN=
BOARD_AUTOMATION_ACTOR_PHONE=
BOARD_AUTOMATION_ACTOR_NAME=보험소식 브리핑
