NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only current app-session signing key for a verified web session with no HttpOnly cookie.
# No Request Board bridge secret is an allowed fallback.
FC_APP_SESSION_TOKEN_SECRET=

# Request Board sender FC_ONBOARDING_NOTIFY_TOKEN must use the same value.
# Keep this server-only; never rename it with a NEXT_PUBLIC_ prefix.
REQUEST_BOARD_NOTIFY_TOKEN=

NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:
ADMIN_PUSH_SECRET=
NEXT_PUBLIC_REQUEST_BOARD_URL=

NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
# Set to 1 for local/CI verification builds that must never upload source maps.
SENTRY_DISABLE_UPLOAD=
SENTRY_READ_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=garamin-web
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
