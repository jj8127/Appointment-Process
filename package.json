    "jest-expo": "~54.0.17",
    "lint-staged": "^16.2.7",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "expo": {
      "node-forge": "1.4.0",
      "postcss": "8.5.19",
      "tar": "7.5.20",
      "uuid": "11.1.1"
    },
    "expo-mcp": {
      "@modelcontextprotocol/sdk": "1.29.0"
    },
    "expo-updates": {
      "node-forge": "1.4.0"
    },
    "react-native": {
      "react-devtools-core": {
        "shell-quote": "1.10.0"
      }
    },
    "sp-react-native-in-app-updates": {
      "axios": "1.18.1",
      "underscore": "1.13.8"
    },
    "ts-jest": {
      "handlebars": "4.7.9"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "private": true
