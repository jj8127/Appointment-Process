{
  "name": "fc-onboarding-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "node --experimental-websocket ./node_modules/expo/bin/cli export --platform web",
    "web": "expo start --web",
    "eas:build:android": "node ./scripts/eas-build.js android production",
    "eas:build:ios": "node ./scripts/eas-build.js ios production --non-interactive --freeze-credentials",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "report:legacy-recommenders": "node ./scripts/reporting/reconcile-legacy-recommenders.mjs",
    "report:missing-recommender": "node ./scripts/reporting/export-missing-recommender-report.mjs",
    "report:missing-recommender-outreach": "node ./scripts/reporting/export-missing-recommender-outreach-report.mjs",
    "ops:send-missing-recommender-messages": "node ./scripts/reporting/send-missing-recommender-messages.mjs",
    "ops:post-insurance-digest": "node ./scripts/ops/post-insurance-digest.mjs",
    "ops:sentry-triage": "node ./scripts/ops/sentry-daily-triage.mjs",
    "qa:init:integrated": "node ./scripts/testing/init-integrated-test-run.mjs",
    "qa:validate:integrated": "node ./scripts/testing/validate-integrated-test-run.mjs",
    "governance:install-hook": "node ./scripts/ci/install-governance-hook.mjs",
    "governance:pre-push": "node ./scripts/ci/pre-push-governance.mjs",
    "prepare": "node ./scripts/prepare.js"
  },
  "dependencies": {
