{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  "claude.view.height": "100%",
  "claude.view.position": "right",
  "deno.enablePaths": ["supabase/functions"],
  "deno.lint": true,
  "deno.unstable": false,
  "json.schemas": [
    {
      "fileMatch": ["app.json"],
      "schema": {
        "type": "object",
        "properties": {
          "expo": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    }
  ]
}
